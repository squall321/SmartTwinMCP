{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "echo args",
  "type": "object",
  "additionalProperties": false,
  "required": ["message"],
  "properties": {
    "message": {
      "type": "string",
      "description": "Text to echo back."
    },
    "count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 1,
      "description": "How many times to repeat the message."
    }
  }
}
